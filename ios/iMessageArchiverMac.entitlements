<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>com.apple.developer.icloud-container-identifiers</key>
    <array>
        <string>iCloud.com.slw.imessage-archiver</string>
    </array>
    <key>com.apple.developer.icloud-services</key>
    <array>
        <string>CloudDocuments</string>
    </array>
    <key>com.apple.developer.ubiquity-container-identifiers</key>
    <array>
        <string>iCloud.com.slw.imessage-archiver</string>
    </array>
    <!--
        App Sandbox is intentionally DISABLED for the Mac target.

        Reason: a sandboxed Mac app cannot use raw POSIX open() on files
        inside the iCloud-managed Mobile Documents/ tree, even with the
        ubiquity-container entitlement. SQLite (via GRDB) does raw open
        and fails with SQLITE_CANTOPEN. The proper fix would be to wrap
        all DB access in NSFileCoordinator; until that lands, the Mac
        app runs un-sandboxed.

        Trade-offs:
        - No Mac App Store distribution (sandbox is mandatory there).
        - Still signed by the user's Apple Developer Team ID. Notarisation
          is still possible.
        - The app is read-only against the bundle; no security regression
          beyond losing sandbox-induced isolation.
    -->
</dict>
</plist>
